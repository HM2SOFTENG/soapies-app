# ─── Required ─────────────────────────────────────────────────────────────────
# MySQL connection string (local or managed)
DATABASE_URL=mysql://root:password@localhost:3306/soapies

# JWT secret for session cookies (generate a random 64-char string)
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# OAuth configuration
OAUTH_SERVER_URL=https://your-oauth-provider.com
VITE_APP_ID=your-app-id
OWNER_OPEN_ID=your-owner-open-id

# ─── Optional ────────────────────────────────────────────────────────────────
# Server port (defaults to 3000)
PORT=3000

# LLM API (if using AI features)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# SendGrid (for email notifications)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Twilio (for SMS notifications + OTP)
# Prefer TWILIO_FROM_NUMBER. TWILIO_PHONE_NUMBER is also accepted for backward compatibility.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# S3-compatible storage (for photo uploads)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
