# Soapies Mobile — Environment Variables
# Copy to .env.local for development, or configure in EAS/CI secrets for preview/production.

# Required public runtime config
EXPO_PUBLIC_API_URL=https://api.example.com
EXPO_PUBLIC_WEB_URL=https://soapies.example.com

# Optional Expo project metadata
EXPO_PUBLIC_PROJECT_ID=your-expo-project-id

# Optional release metadata hooks
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_ENVIRONMENT=development
