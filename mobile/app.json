        {
          "icon": "./assets/icon.png",
          "color": "#EC4899",
          "sounds": []
        }
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Soapies accesses your photos so you can upload profile pictures and attach images to posts and messages.",
